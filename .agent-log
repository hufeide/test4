{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_78f52e3c6716479698c68c47","type":"tool_result","content":"1\t<template>\n2\t  <div v-if=\"showModal\" class=\"need-help-modal-overlay\">\n3\t    <div class=\"need-help-modal-content\">\n4\t      <div class=\"need-help-modal-header\">\n5\t        <h3>{{ needLabel }}</h3>\n6\t        <button class=\"close-btn\" @click=\"closeModal\">✕</button>\n7\t      </div>\n8\t      <div class=\"need-help-modal-body\">\n9\t        <div class=\"help-section\">\n10\t          <h4>Why it decreases</h4>\n11\t          <p>{{ reason }}</p>\n12\t        </div>\n13\t        <div class=\"help-section\">\n14\t          <h4>How to increase</h4>\n15\t          <p>{{ actions }}</p>\n16\t        </div>\n17\t      </div>\n18\t    </div>\n19\t  </div>\n20\t</template>\n21\t\n22\t<script>\n23\texport default {\n24\t  name: 'NeedHelpModal',\n25\t  props: {\n26\t    show: {\n27\t      type: Boolean,\n28\t      default: false\n29\t    },\n30\t    needType: {\n31\t      type: String,\n32\t      required: true\n33\t    }\n34\t  },\n35\t  emits: ['close'],\n36\t  data() {\n37\t    return {\n38\t      showModal: false,\n39\t      helpContent: {\n40\t        happiness: {\n41\t          label: 'Happiness (❤️)',\n42\t          reason: 'Neglect or loneliness causes happiness to decrease',\n43\t          actions: 'Petting your pet, playing games together'\n44\t        },\n45\t        hunger: {\n46\t          label: 'Hunger (🍗)',\n47\t          reason: 'Time passes and hunger naturally increases',\n48\t          actions: 'Feeding your pet regularly'\n49\t        },\n50\t        health: {\n51\t          label: 'Health (❤️)',\n52\t          reason: 'Poor care or illness causes health to decrease',\n53\t          actions: 'Providing proper care, giving medicine when needed'\n54\t        },\n55\t        energy: {\n56\t          label: 'Energy (⚡)',\n57\t          reason: 'Activity decreases energy, lack of sleep also affects it',\n58\t        