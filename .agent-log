   showHelpModal: false,\n63\t      currentHelpNeed: '',\n64\t      needs: [\n65\t        { type: 'happiness', label: 'Happiness', icon: '❤️', value: 80, max: 100 },\n66\t        { type: 'hunger', label: 'Hunger', icon: '🍗', value: 60, max: 100 },\n67\t        { type: 'health', label: 'Health', icon: '❤️', value: 90, max: 100 },\n68\t        { type: 'energy', label: 'Energy', icon: '⚡', value: 70, max: 100 },\n69\t        { type: 'sleep', label: 'Sleep', icon: '💤', value: 40, max: 100 },\n70\t        { type: 'play', label: 'Play', icon: '⚽', value: 50, max: 100 },\n71\t        { type: 'love', label: 'Love', icon: '💖', value: 85, max: 100 },\n72\t        { type: 'chat', label: 'Chat', icon: '💬', value: 30, max: 100 },\n73\t        { type: 'knowledge', label: 'Knowledge', icon: '📚', value: 45, max: 100 }\n74\t      ]\n75\t    };\n76\t  },\n77\t  methods: {\n78\t    getBarColorClass(value, max) {\n79\t      const percentage = (value / max) * 100;\n80\t      if (percentage < 30) return 'need-low';\n81\t      if (percentage < 70) return 'need-medium';\n82\t      return 'need-high';\n83\t    },\n84\t    showHelp(needType) {\n85\t      this.currentHelpNeed = needType;\n86\t      this.showHelpModal = true;\n87\t    },\n88\t    closeHelpModal() {\n89\t      this.showHelpModal = false;\n90\t      this.currentHelpNeed = '';\n91\t    }\n92\t  }\n93\t};\n94\t</script>\n95\t\n96\t<style>\n97\t* {\n98\t  margin: 0;\n99\t  padding: 0;\n100\t  box-sizing: border-box;\n101\t}\n102\t\n103\tbody {\n104\t  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;\n105\t  background-color: #f0f2f5;\n106\t  min-height: 100vh;\n107\t}\n108\t\n109\t.app {\n110\t  max-width: 800px;\n111\t  margin: 0 auto;\n112\t  padding: 20px;\n113\t}\n114\t\n115\t.app-title {\n116\t  text-align: center;\n117\t  color: #333;\n118\t  margin-bottom: 24px;\n119\t  font-size: 28px;\n120\t}\n121\t\n122\t.section-title {\n123\t  font-size: 18px;\n124\t  font-weight: 600;\n125